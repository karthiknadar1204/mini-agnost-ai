# ── logsneat backend (apps/server) ──

# Neon Postgres connection string
DATABASE_URL=""

# Long random secret for signing dashboard JWTs (change in prod!)
JWT_SECRET=replace-with-a-long-random-secret

# Redis for the detections worker queue (managed, e.g. Upstash, in prod)
REDIS_URL=redis://localhost:6379

# Comma-separated dashboard origins allowed by CORS.
# In prod set this to your deployed frontend URL, e.g. https://app.logsneat.com
CORS_ORIGINS=http://localhost:3000

# Port to listen on (most hosts inject PORT automatically)
PORT=3004
